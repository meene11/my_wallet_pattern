{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02. 감정 기반 소비 분석 (NLP)\n",
    "## 개인 소비 분석 + 무의식 지출 탐지 AI\n",
    "\n",
    "**목표:**\n",
    "- 지출 메모에서 감정 키워드 자동 추출\n",
    "- 감정 × 지출금액 패턴 시각화\n",
    "- 어떤 감정일 때 얼마나 더 쓰는지 수치화"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0. 라이브러리 임포트"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from collections import Counter\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.rcParams['font.family'] = 'Malgun Gothic'\n",
    "plt.rcParams['axes.unicode_minus'] = False\n",
    "\n",
    "print('라이브러리 로드 완료!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 전처리 데이터 로드"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('../data/processed/spending_processed.csv')\n",
    "df['date'] = pd.to_datetime(df['date'])\n",
    "\n",
    "# 메모가 있는 데이터만\n",
    "memo_df = df[df['memo'].notna() & (df['memo'] != '')].copy()\n",
    "print(f'전체: {len(df)}건 / 메모 있음: {len(memo_df)}건')\n",
    "memo_df[['date', 'category', 'amount', 'memo']].head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 규칙 기반 감정 키워드 추출\n",
    "> HuggingFace 모델 대신 우선 키워드 사전으로 빠르게 구현"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 감정 카테고리별 키워드 사전\n",
    "EMOTION_DICT = {\n",
    "    '스트레스': ['스트레스', '답답', '짜증', '힘들', '지쳐', '피곤'],\n",
    "    '보상심리': ['보상', '위로', '선물', '기념', '그냥', '질러'],\n",
    "    '충동':     ['충동', '새벽', '갑자기', '또', '또 해버렸', '해버렸'],\n",
    "    '우울':     ['우울', '울적', '슬픔', '기분 안 좋', '기분이 안'],\n",
    "    '즐거움':   ['즐거', '행복', '좋아', '신남', '신나'],\n",
    "    '폭식':     ['폭식', '많이', '먹고 싶', '치킨', '마라탕'],\n",
    "    '사회적':   ['친구', '가족', '모임', '만남', '회식'],\n",
    "}\n",
    "\n",
    "def extract_emotions(text):\n",
    "    if pd.isna(text) or text == '':\n",
    "        return []\n",
    "    text = str(text)\n",
    "    found = []\n",
    "    for emotion, keywords in EMOTION_DICT.items():\n",
    "        if any(kw in text for kw in keywords):\n",
    "            found.append(emotion)\n",
    "    return found if found else ['중립']\n",
    "\n",
    "memo_df['emotions'] = memo_df['memo'].apply(extract_emotions)\n",
    "memo_df['emotion_str'] = memo_df['emotions'].apply(lambda x: ', '.join(x))\n",
    "\n",
    "memo_df[['memo', 'amount', 'emotion_str']].head(15)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 감정 × 지출금액 분석"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 감정별 건수와 평균 금액 계산\n",
    "rows = []\n",
    "for _, row in memo_df.iterrows():\n",
    "    for emotion in row['emotions']:\n",
    "        rows.append({'emotion': emotion, 'amount': row['amount'], 'category': row['category']})\n",
    "\n",
    "emotion_df = pd.DataFrame(rows)\n",
    "emotion_stat = emotion_df.groupby('emotion').agg(\n",
    "    건수=('amount', 'count'),\n",
    "    총지출=('amount', 'sum'),\n",
    "    평균지출=('amount', 'mean')\n",
    ").sort_values('평균지출', ascending=False).reset_index()\n",
    "\n",
    "print(emotion_stat.to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# 감정별 평균 지출\n",
    "colors = ['#FF6B6B' if e != '중립' and e != '즐거움' and e != '사회적' \n",
    "          else '#4ECDC4' for e in emotion_stat['emotion']]\n",
    "axes[0].barh(emotion_stat['emotion'][::-1], emotion_stat['평균지출'][::-1], color=colors[::-1])\n",
    "axes[0].set_xlabel('평균 지출 (원)')\n",
    "axes[0].set_title('감정별 평균 지출금액', fontsize=13)\n",
    "for i, v in enumerate(emotion_stat['평균지출'][::-1]):\n",
    "    axes[0].text(v + 100, i, f'{v:,.0f}원', va='center', fontsize=9)\n",
    "\n",
    "# 감정별 건수\n",
    "axes[1].bar(emotion_stat['emotion'], emotion_stat['건수'], color=colors)\n",
    "axes[1].set_ylabel('거래 건수')\n",
    "axes[1].set_title('감정별 거래 건수', fontsize=13)\n",
    "axes[1].tick_params(axis='x', rotation=30)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/05_emotion_analysis.png', dpi=120, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 감정 기반 소비 패턴 인사이트"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 중립 감정 대비 각 감정의 소비 배수\n",
    "neutral_avg = emotion_stat[emotion_stat['emotion'] == '중립']['평균지출'].values\n",
    "if len(neutral_avg) > 0:\n",
    "    neutral_avg = neutral_avg[0]\n",
    "    print(f'중립(감정 없을 때) 평균 지출: {neutral_avg:,.0f}원\\n')\n",
    "    print('감정별 소비 배수:')\n",
    "    for _, row in emotion_stat.iterrows():\n",
    "        if row['emotion'] != '중립':\n",
    "            multiplier = row['평균지출'] / neutral_avg\n",
    "            bar = '█' * int(multiplier * 5)\n",
    "            print(f\"  {row['emotion']:8s}: {multiplier:.1f}배  {bar}\")\n",
    "else:\n",
    "    print('중립 데이터 없음')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 감정 × 카테고리 히트맵\n",
    "emotion_cat = emotion_df.pivot_table(\n",
    "    values='amount', index='emotion', columns='category',\n",
    "    aggfunc='mean', fill_value=0\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "sns.heatmap(emotion_cat, annot=True, fmt='.0f', cmap='Reds',\n",
    "            linewidths=0.5, ax=ax, cbar_kws={'label': '평균금액(원)'})\n",
    "ax.set_title('감정 × 카테고리 평균 지출 히트맵', fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../data/processed/06_emotion_category_heatmap.png', dpi=120, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. (선택) HuggingFace 감정 분류 모델 적용\n",
    "> 위 규칙 기반 분석이 완성된 후, 아래 셀을 실행해 모델 기반 분석으로 업그레이드"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 주의: 첫 실행 시 모델 다운로드 (약 500MB) ──\n",
    "# pip install transformers torch sentencepiece\n",
    "\n",
    "USE_MODEL = False  # True로 바꾸면 모델 실행\n",
    "\n",
    "if USE_MODEL:\n",
    "    from transformers import pipeline\n",
    "    \n",
    "    # 한국어 감정 분석 모델 (snunlp/KR-FinBert-SC 또는 beomi/kcbert-base)\n",
    "    classifier = pipeline(\n",
    "        'text-classification',\n",
    "        model='snunlp/KR-FinBert-SC',\n",
    "        top_k=1\n",
    "    )\n",
    "    \n",
    "    sample_texts = memo_df['memo'].dropna().head(5).tolist()\n",
    "    for text in sample_texts:\n",
    "        result = classifier(text)\n",
    "        print(f'메모: {text}')\n",
    "        print(f'감정: {result}\\n')\n",
    "else:\n",
    "    print('USE_MODEL = True 로 바꾸면 HuggingFace 모델 실행됩니다.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 요약"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=' * 50)\n",
    "print('감정 분석 요약')\n",
    "print('=' * 50)\n",
    "print(f'메모 있는 거래: {len(memo_df)}건')\n",
    "top_emotion = emotion_stat.iloc[0]\n",
    "print(f'가장 비싼 소비 감정: {top_emotion[\"emotion\"]} (평균 {top_emotion[\"평균지출\"]:,.0f}원)')\n",
    "most_frequent = emotion_stat.sort_values('건수', ascending=False).iloc[0]\n",
    "print(f'가장 빈번한 감정: {most_frequent[\"emotion\"]} ({most_frequent[\"건수\"]}건)')\n",
    "print('=' * 50)\n",
    "print('\\n다음 단계: 03_anomaly_detection.ipynb (이상 탐지)')"
   ]
  }
 ],
